import asyncio
import base64
from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
from rabbit_mcp import McpServer, Tool
from genetix_sdk import GenetixTwin
import tor_request  # Onion routing
import socket

class DNAProxyNode:
    def __init__(self, dna_twin_id=1, vsn="7443-67DD"):
        self.twin = GenetixTwin(dna_twin_id)
        self.mcp = McpServer(f"DNA-PROXY-{vsn}")
        self.dna_key = self.extract_dna_aes_key()
        self.proxy_port = 9050  # Tor SOCKS
        
    def extract_dna_aes_key(self):
        """Extract 256-bit AES key from DNA twin Merkle root"""
        merkle_hash = self.twin.merkle_root
        # First 32 bytes = AES-256 key
        return base64.b64decode(merkle_hash[:43])  # 32 bytes base64
    
    @mcp_tool("human_to_node")
    async def human_to_llm(self, human_signal):
        """HUMAN → DNA → NODE → LLM (gaze/voice/EEG)"""
        # 1. Encrypt human signal with DNA key
        cipher = Cipher(algorithms.AES(self.dna_key), modes.GCM())
        encryptor = cipher.encryptor()
        ciphertext = encryptor.update(human_signal.encode()) + encryptor.finalize()
        
        # 2. Route through DNA-secured proxy network
        async with tor_request.TorRequest(proxy_port=9050) as tr:
            response = await tr.post(
                "http://rabbit-mcp-node.onion/api/llm",
                json={"ciphertext": base64.b64encode(ciphertext).decode()}
            )
        
        # 3. Decrypt LLM response
        decryptor = cipher.decryptor()
        plaintext = decryptor.update(response.content) + decryptor.finalize()
        return plaintext.decode()
    
    @mcp_tool("llm_to_human")
    async def llm_to_human(self, llm_response):
        """LLM → NODE → DNA → HUMAN (2-way)"""
        # Encrypt with DNA key for human device
        cipher = Cipher(algorithms.AES(self.dna_key), modes.GCM())
        encryptor = cipher.encryptor()
        ciphertext = encryptor.update(llm_response.encode()) + encryptor.finalize()
        
        # Push to human device via WebSocket + Tor
        await self.websocket.send(base64.b64encode(ciphertext))
        return "Delivery confirmed"
    
    async def run_proxy_server(self):
        """DNA-secured SOCKS5 proxy"""
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.bind(('0.0.0.0', self.proxy_port))
        sock.listen(5)
        
        while True:
            client, addr = sock.accept()
            asyncio.create_task(self.handle_proxy_connection(client, addr))

# Deploy node
node = DNAProxyNode()
asyncio.run(node.run_proxy_server()) 

